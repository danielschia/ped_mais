# Ignore the Git directory and associated files
.git/
.gitignore

# Ignore logs and temporary files (but keep the directories so Rails can write to them)
log/*
!log/.keep
tmp/*
!tmp/.keep

# Ignore bundler config and locally installed gems (they will be installed inside the container)
.bundle
vendor/bundle

# Ignore environment files and sensitive keys (use Docker secrets or environment variables instead)
.env*
!.env.example
config/master.key
config/credentials/*.key

# Ignore build artifacts and node modules (if using a separate build stage for assets)
node_modules/
app/assets/builds/*
!app/assets/builds/.keep
public/assets
public/packs/ # For older Webpacker setups

# Ignore development/console history files
.byebug_history
.pry_history
.bash_history

# Ignore storage files in development (e.g., SQLite DBs, uploaded files)
storage/*
!storage/.keep

# Ignore other Docker-related files to prevent conflicts
.dockerignore
Dockerfile*
docker-compose*.yml
